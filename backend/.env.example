# Server
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# AI Provider (gemini | openai | claude)
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Batch processing
AI_BATCH_SIZE=50
AI_MAX_RETRIES=3
AI_RETRY_BASE_DELAY_MS=1000

# Upload limits
MAX_FILE_SIZE_MB=10
